{
  "expo": {
    "name": "rx delivery",
    "slug": "driver-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rxrouteoptimizer.driverapp",
      "buildNumber": "13",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location is used to track your delivery position in real-time.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Location is used to track your delivery position even when the app is in the background.",
        "NSCameraUsageDescription": "Camera is used to scan package barcodes and capture proof of delivery.",
        "NSPhotoLibraryUsageDescription": "Photo library is used to attach proof of delivery photos.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "backgroundColor": "#111827"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111827"
      },
      "package": "com.rxro.driver",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-location",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Driver App to access camera for barcode scanning and proof of delivery photos."
        }
      ],
      "expo-image-picker",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#111827"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "58067994-4398-4cc3-89e8-14945f2c74d7"
      }
    }
  }
}
